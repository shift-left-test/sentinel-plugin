<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                            https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!-- Exclude generated Messages classes -->
    <Match>
        <Class name="~.*\.Messages"/>
    </Match>

    <!-- SentinelGlobalConfiguration: load() in constructor is the standard Jenkins
         GlobalConfiguration pattern required by the framework -->
    <Match>
        <Class name="io.jenkins.plugins.sentinel.SentinelGlobalConfiguration"/>
        <Bug pattern="MC_OVERRIDABLE_METHOD_CALL_IN_CONSTRUCTOR"/>
    </Match>

    <!-- AfterPartitionCallback: inner class holds reference to outer StepExecution
         which is required to access getContext(); outer class is also Serializable -->
    <Match>
        <Class name="io.jenkins.plugins.sentinel.SentinelOrchestrator$AfterPartitionCallback"/>
        <Bug pattern="SE_INNER_CLASS"/>
    </Match>

</FindBugsFilter>
